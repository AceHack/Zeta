root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{fs,fsi,fsx}]
indent_size = 4
fsharp_single_argument_web_mode = true

[*.{cs,csproj,fsproj}]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false

[*.{props,targets,config,xml}]
indent_size = 2

[Makefile]
indent_style = tab
